<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Access Blocked</title>
  <style>
    * {
      box-sizing: border-box;
    }
    body {
      font-family: Roboto, 'Helvetica Neue', Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      background: linear-gradient(135deg, #8a8a8a 0%, #5a5a5a 100%);
      margin: 0;
      color: #333;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .container {
      padding: 2.5em 1.25em;
      max-width: 50%;
      width: 100%;
      transform: translateY(-12.5vh);
    }
    .card {
      background: #fff;
      border-radius: 0.25em;
      padding: 2.5em 2.5em;
      box-shadow: 0 1em 4em rgba(0,0,0,0.7), 0 0.5em 2em rgba(0,0,0,0.5);
    }
    .card-header {
      background: linear-gradient(to bottom, #3a3a3a 0%, #1f1f1f 100%);
      padding: 1.25em 1.875em;
      margin: -2.5em -2.5em 1.5em -2.5em;
      border-radius: 0.25em 0.25em 0 0;
      font-weight: 700;
      font-size: 1.1em;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
    }
    .card-header img {
      height: 5em;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 0.125em 0.25em rgba(0,0,0,0.2));
    }
    h1 {
      color: #333;
      font-size: 1.5em;
      margin-bottom: 1.25em;
      font-weight: normal;
    }
    .message {
      color: #333;
      font-size: 1.1em;
      line-height: 2.2;
      margin-bottom: 2em;
      padding: 4.5em 2em;
      background-color: #f7f6f5;
      border-radius: 0.25em;
    }
    .actions {
      display: flex;
      gap: 0.625em;
    }
    .btn {
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
      padding: 0.75em 1.5em;
      border-radius: 0.25em;
      border: none;
      cursor: pointer;
      font-size: 1em;
      font-weight: 500;
      transition: all 0.2s;
      box-shadow: 0 0.25em 0.5em rgba(0,0,0,0.25), 0 0.125em 0.25em rgba(0,0,0,0.15);
    }
    .btn-primary {
      background: linear-gradient(to bottom, #3a3a3a 0%, #1f1f1f 100%);
      color: #fff;
    }
    .btn-primary:focus {
      outline: 0.175em solid #ffe375;
      outline-offset: 0.125em;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card" aria-labelledby="blocked-title" aria-describedby="blocked-desc">
      <div class="card-header">
		<img src="data:image/png;base64," alt="F5 Logo">
      </div>
      
      <h1 id="blocked-title">Access to this resource has been blocked</h1>
      
      <div class="message" id="blocked-desc" role="alert">$receive_msg</div>
      
      <div class="actions">
        <button class="btn btn-primary" onclick="history.back()">Go Back</button>
      </div>
    </div>
  </div>
</body>
</html>
